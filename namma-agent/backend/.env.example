# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# LiteLLM Configuration
LITELLM_API_URL=http://localhost:4000
LITELLM_API_KEY=your_litellm_api_key
LITELLM_MODEL=gpt-4o-mini

# OCR Configuration
# Option 1: OCR.space (Recommended - Free tier: 25,000 requests/month, no credit card)
# Get your free API key at: https://ocr.space/ocrapi/freekey
OCR_SPACE_API_KEY=your_ocr_space_api_key_here

# Option 2: Google Cloud Vision (requires billing account)
# GOOGLE_APPLICATION_CREDENTIALS=gcv.json
# GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# MongoDB Configuration
# Get your free MongoDB Atlas cluster at: https://www.mongodb.com/cloud/atlas
# Connection string format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/namma-agent
# Or use local MongoDB: mongodb://localhost:27017/namma-agent
